{
  "name": "aurora-preview",
  "displayName": "Aurora Preview — Markdown Preview, PDF Export & Mermaid",
  "description": "A gorgeous, terminal-glass Markdown preview for VS Code with live rendering, Mermaid & KaTeX, deep theming, and PDF/HTML export.",
  "version": "0.0.1",
  "publisher": "abhishek",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Visualization",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "markdown preview",
    "preview",
    "pdf",
    "export",
    "html",
    "mermaid",
    "katex",
    "math",
    "diagram",
    "toc",
    "viewer",
    "md",
    "presentation"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "auroraPreview.open",
        "title": "Aurora: Open Preview to the Side",
        "category": "Aurora"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "auroraPreview.open",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "auroraPreview.open",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "build:webview": "vite build",
    "build": "npm run build:webview && npm run compile",
    "test:unit": "vitest run",
    "pretest:integration": "tsc -p tsconfig.json --outDir dist-test",
    "test:integration": "vscode-test",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "svelte": "^5.56.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
